# LLM 어댑터 설정 (하나만 활성화)

# --- Ollama 로컬 모델 (무료) ---
LLM_API_KEY=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5:0.5b   # 메모리 여유가 있으면 qwen2.5:3b 또는 qwen2.5:7b 사용 가능

# --- OpenAI ---
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

